<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="2026-03-23" ReportInfo.Modified="2026-03-23" ReportInfo.CreatorVersion="1.0">
  <Dictionary>
    <TableDataSource Name="groups" Alias="groups" DataType="Table">
      <Column Name="group_name" DataType="System.String"/>
      <Column Name="english_level" DataType="System.String"/>
      <Column Name="maestro" DataType="System.String"/>
      <Column Name="max_capacity" DataType="System.Int32"/>
      <Column Name="estudiantes_inscritos" DataType="System.Int32"/>
      <Column Name="cupo_disponible" DataType="System.Int32"/>
    </TableDataSource>
  </Dictionary>
  <ReportPage PaperHeight="11in" PaperWidth="8.5in">
    <ReportTitleBand Height="1in">
      <TextObject Name="Title" Left="0.1in" Top="0.1in" Width="8.3in" Height="0.4in" Text="Reporte de Grupos" HorzAlign="Center" Font="Segoe UI, 18pt, style=Bold"/>
      <TextObject Name="Date" Left="7in" Top="0.5in" Width="1.4in" Height="0.3in" Text="Fecha: [DateTime.Now.ToString(&quot;dd/MM/yyyy&quot;)]"/>
    </ReportTitleBand>
    <PageHeaderBand Height="0.4in">
      <TextObject Name="Header1" Left="0.1in" Top="0in" Width="1.2in" Height="0.3in" Text="Grupo" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header2" Left="1.4in" Top="0in" Width="0.7in" Height="0.3in" Text="Nivel" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header3" Left="2.2in" Top="0in" Width="1.2in" Height="0.3in" Text="Maestro" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header4" Left="3.5in" Top="0in" Width="0.8in" Height="0.3in" Text="Capacidad" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header5" Left="4.4in" Top="0in" Width="0.9in" Height="0.3in" Text="Inscritos" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header6" Left="5.4in" Top="0in" Width="0.8in" Height="0.3in" Text="Cupo" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
    </PageHeaderBand>
    <DataBand Name="Data" DataSource="groups" Height="0.25in">
      <TextObject Name="Field1" Left="0.1in" Top="0in" Width="1.2in" Height="0.25in" Text="[groups.group_name]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field2" Left="1.4in" Top="0in" Width="0.7in" Height="0.25in" Text="[groups.english_level]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field3" Left="2.2in" Top="0in" Width="1.2in" Height="0.25in" Text="[groups.maestro]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field4" Left="3.5in" Top="0in" Width="0.8in" Height="0.25in" Text="[groups.max_capacity]" Font="Segoe UI, 9pt" HorzAlign="Center"/>
      <TextObject Name="Field5" Left="4.4in" Top="0in" Width="0.9in" Height="0.25in" Text="[groups.estudiantes_inscritos]" Font="Segoe UI, 9pt" HorzAlign="Center"/>
      <TextObject Name="Field6" Left="5.4in" Top="0in" Width="0.8in" Height="0.25in" Text="[groups.cupo_disponible]" Font="Segoe UI, 9pt" HorzAlign="Center"/>
    </DataBand>
    <PageFooterBand Height="0.3in">
      <TextObject Name="PageNum" Left="7in" Top="0.05in" Width="1.4in" Height="0.2in" Text="Página: [Page#]" HorzAlign="Right"/>
    </PageFooterBand>
  </ReportPage>
</Report>
