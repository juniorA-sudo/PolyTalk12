<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="2026-03-23" ReportInfo.Modified="2026-03-23" ReportInfo.CreatorVersion="1.0">
  <Dictionary>
    <TableDataSource Name="teachers" Alias="teachers" DataType="Table">
      <Column Name="username" DataType="System.String"/>
      <Column Name="email" DataType="System.String"/>
      <Column Name="phone" DataType="System.String"/>
      <Column Name="specialization" DataType="System.String"/>
      <Column Name="hire_date" DataType="System.DateTime"/>
      <Column Name="grupos_asignados" DataType="System.Int32"/>
      <Column Name="estado" DataType="System.String"/>
    </TableDataSource>
  </Dictionary>
  <ReportPage PaperHeight="11in" PaperWidth="8.5in">
    <ReportTitleBand Height="1in">
      <TextObject Name="Title" Left="0.1in" Top="0.1in" Width="8.3in" Height="0.4in" Text="Reporte de Maestros" HorzAlign="Center" Font="Segoe UI, 18pt, style=Bold"/>
      <TextObject Name="Date" Left="7in" Top="0.5in" Width="1.4in" Height="0.3in" Text="Fecha: [DateTime.Now.ToString(&quot;dd/MM/yyyy&quot;)]"/>
    </ReportTitleBand>
    <PageHeaderBand Height="0.4in">
      <TextObject Name="Header1" Left="0.1in" Top="0in" Width="0.8in" Height="0.3in" Text="Usuario" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header2" Left="1in" Top="0in" Width="1.3in" Height="0.3in" Text="Email" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header3" Left="2.4in" Top="0in" Width="0.9in" Height="0.3in" Text="Teléfono" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header4" Left="3.4in" Top="0in" Width="1.2in" Height="0.3in" Text="Especialidad" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header5" Left="4.7in" Top="0in" Width="0.7in" Height="0.3in" Text="Contrato" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header6" Left="5.5in" Top="0in" Width="0.7in" Height="0.3in" Text="Grupos" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header7" Left="6.3in" Top="0in" Width="1.2in" Height="0.3in" Text="Estado" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
    </PageHeaderBand>
    <DataBand Name="Data" DataSource="teachers" Height="0.25in">
      <TextObject Name="Field1" Left="0.1in" Top="0in" Width="0.8in" Height="0.25in" Text="[teachers.username]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field2" Left="1in" Top="0in" Width="1.3in" Height="0.25in" Text="[teachers.email]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field3" Left="2.4in" Top="0in" Width="0.9in" Height="0.25in" Text="[teachers.phone]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field4" Left="3.4in" Top="0in" Width="1.2in" Height="0.25in" Text="[teachers.specialization]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field5" Left="4.7in" Top="0in" Width="0.7in" Height="0.25in" Text="[teachers.hire_date.ToString(&quot;dd/MM/yyyy&quot;)]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field6" Left="5.5in" Top="0in" Width="0.7in" Height="0.25in" Text="[teachers.grupos_asignados]" Font="Segoe UI, 9pt" HorzAlign="Center"/>
      <TextObject Name="Field7" Left="6.3in" Top="0in" Width="1.2in" Height="0.25in" Text="[teachers.estado]" Font="Segoe UI, 9pt"/>
    </DataBand>
    <PageFooterBand Height="0.3in">
      <TextObject Name="PageNum" Left="7in" Top="0.05in" Width="1.4in" Height="0.2in" Text="Página: [Page#]" HorzAlign="Right"/>
    </PageFooterBand>
  </ReportPage>
</Report>
