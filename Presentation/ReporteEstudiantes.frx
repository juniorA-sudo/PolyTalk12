<?xml version="1.0" encoding="utf-8"?>
<Report ScriptLanguage="CSharp" ReportInfo.Created="2026-03-23" ReportInfo.Modified="2026-03-23" ReportInfo.CreatorVersion="1.0">
  <Dictionary>
    <TableDataSource Name="students" Alias="students" DataType="Table">
      <Column Name="username" DataType="System.String"/>
      <Column Name="email" DataType="System.String"/>
      <Column Name="phone" DataType="System.String"/>
      <Column Name="current_english_level" DataType="System.String"/>
      <Column Name="enrollment_date" DataType="System.DateTime"/>
      <Column Name="group_name" DataType="System.String"/>
      <Column Name="maestro" DataType="System.String"/>
      <Column Name="estado" DataType="System.String"/>
    </TableDataSource>
  </Dictionary>
  <ReportPage PaperHeight="11in" PaperWidth="8.5in">
    <ReportTitleBand Height="1in">
      <TextObject Name="Title" Left="0.1in" Top="0.1in" Width="8.3in" Height="0.4in" Text="Reporte de Estudiantes" HorzAlign="Center" Font="Segoe UI, 18pt, style=Bold"/>
      <TextObject Name="Date" Left="7in" Top="0.5in" Width="1.4in" Height="0.3in" Text="Fecha: [DateTime.Now.ToString(&quot;dd/MM/yyyy&quot;)]"/>
    </ReportTitleBand>
    <PageHeaderBand Height="0.4in">
      <TextObject Name="Header1" Left="0.1in" Top="0in" Width="0.8in" Height="0.3in" Text="Usuario" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header2" Left="1in" Top="0in" Width="1.5in" Height="0.3in" Text="Email" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header3" Left="2.6in" Top="0in" Width="0.9in" Height="0.3in" Text="Teléfono" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header4" Left="3.6in" Top="0in" Width="0.6in" Height="0.3in" Text="Nivel" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header5" Left="4.3in" Top="0in" Width="0.8in" Height="0.3in" Text="Ingreso" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header6" Left="5.2in" Top="0in" Width="1in" Height="0.3in" Text="Grupo" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header7" Left="6.3in" Top="0in" Width="0.9in" Height="0.3in" Text="Maestro" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
      <TextObject Name="Header8" Left="7.3in" Top="0in" Width="1in" Height="0.3in" Text="Estado" Font="Segoe UI, 10pt, style=Bold" Border.Lines="Bottom"/>
    </PageHeaderBand>
    <DataBand Name="Data" DataSource="students" Height="0.25in">
      <TextObject Name="Field1" Left="0.1in" Top="0in" Width="0.8in" Height="0.25in" Text="[students.username]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field2" Left="1in" Top="0in" Width="1.5in" Height="0.25in" Text="[students.email]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field3" Left="2.6in" Top="0in" Width="0.9in" Height="0.25in" Text="[students.phone]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field4" Left="3.6in" Top="0in" Width="0.6in" Height="0.25in" Text="[students.current_english_level]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field5" Left="4.3in" Top="0in" Width="0.8in" Height="0.25in" Text="[students.enrollment_date.ToString(&quot;dd/MM/yyyy&quot;)]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field6" Left="5.2in" Top="0in" Width="1in" Height="0.25in" Text="[students.group_name]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field7" Left="6.3in" Top="0in" Width="0.9in" Height="0.25in" Text="[students.maestro]" Font="Segoe UI, 9pt"/>
      <TextObject Name="Field8" Left="7.3in" Top="0in" Width="1in" Height="0.25in" Text="[students.estado]" Font="Segoe UI, 9pt"/>
    </DataBand>
    <PageFooterBand Height="0.3in">
      <TextObject Name="PageNum" Left="7in" Top="0.05in" Width="1.4in" Height="0.2in" Text="Página: [Page#]" HorzAlign="Right"/>
    </PageFooterBand>
  </ReportPage>
</Report>